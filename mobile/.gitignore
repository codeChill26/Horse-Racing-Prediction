# Git ignore for Dart
# https://github.com/github/gitignore/blob/main/Dart.gitignore

# Compiled Dart files
*.dart_tool/

# Archives
*.zip
*.tar.gz

# Temporary files
*.tmp
*.bak
*.orig

# Flutter/Dart specific
# https://github.com/flutter/flutter/blob/master/.gitignore
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
.dart_tool/
.packages
.pubignore

# Android / iOS
build/
*.jks
*.p8
*.p12
*.mobileprovision
*.xcuserstate
*.xcworkspace
!ios/**/*.xcworkspace

# macOS
.dart_tool/Flutter/ephemeral/
*.xcuserstate

# VS Code
.vscode/

# IntelliJ
*.iml
.idea/

# Lock files
*.lock
pubspec.lock

# UTM / VM
*.vmx
*.vmem

# Generated files
*.g.dart
*.freezed.dart
*.gr.dart
