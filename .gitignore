# =========================================================================
# ROOT .gitignore — Horse Racing Prediction Monorepo
# =========================================================================
# Áp dụng cho toàn bộ project. Các thư mục con (frontend/, backend/)
# sẽ có .gitignore riêng bổ sung thêm.
# =========================================================================

# -------------------------------------------------------------------------
# 1. THƯ VIỆN VÀ PHỤ THUỘC (Dependencies)
# -------------------------------------------------------------------------
node_modules/
frontend/node_modules/
backend/node_modules/
*/node_modules/

# -------------------------------------------------------------------------
# 2. BIẾN MÔI TRƯỜNG VÀ BẢO MẬT (ENV / SECRETS)
# -------------------------------------------------------------------------
# CẢNH BÁO: Không bao giờ đẩy file .env lên Git. Chứa:
#   - Database password / connection string
#   - JWT secret key
#   - API keys (Gmail, Supabase, v.v.)
#   - Admin credentials
.env
.env.local
.env.*.local
*.pem
*.key
credentials.json
secrets.json

# -------------------------------------------------------------------------
# 3. BUILD OUTPUTS
# -------------------------------------------------------------------------
dist/
dist-ssr/
build/
# AI dataset — 133MB dữ liệu đua ngựa 2016-2020 dùng train model, KHÔNG push lên GitHub.
# Chỉ cần cho việc train local (python ai/train.py); model đã train nằm ở ai/models/model.pkl.
docs/horseracing_dataset/
frontend/dist/
backend/public/

# -------------------------------------------------------------------------
# 4. HỆ THỐNG & TRÌNH SOẠN THẢO (OS / IDE)
# -------------------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
*.user
*.userosscache
*.sln.docstates
*.suo
*.ntvs*
*.njsproj
*.sln

# Linux
*~

# JetBrains
.idea/
*.iml
*.ipr
*.iws
atlassian-ide-plugin.xml

# VS Code
.vscode/
!.vscode/extensions.json
!.vscode/settings.json

# Cursor (không đẩy bộ nhớ ngữ cảnh & cấu hình workspace)
.cursor/
.cursorrc
.cursor/rules/
.cursor/prompts/
.cursor/reports/

# -------------------------------------------------------------------------
# 5. TÀI LIỆU & BÁO CÁO (Docs & Reports)
# -------------------------------------------------------------------------
# Các file này thường được generate tự động hoặc chỉ dùng nội bộ
docs/
.cursor/reports/
.cursor/prompts/
*/reports/
*.md.txt

# -------------------------------------------------------------------------
# 6. LOG FILES & NHẬT KÝ
# -------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.log.*

# Backend log files
backend/be.log
backend/be.err.log
backend/*.log
backend/*.err.log

# -------------------------------------------------------------------------
# 7. TEST COVERAGE
# -------------------------------------------------------------------------
coverage/
.nyc_output/
frontend/coverage/
backend/coverage/

# -------------------------------------------------------------------------
# 8. PYTHON / NOTEBOOK
# -------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Jupyter
.ipynb_checkpoints/
*.ipynb

# -------------------------------------------------------------------------
# 9. ARCHIVE FILES
# -------------------------------------------------------------------------
*.tgz
*.tar.gz
*.zip
*.7z
*.rar
*.gz
*.bz2
*.xz
*.lz
*.lzma
*.cab
*.iso
*.img
*.msi
*.apk
*.ipa
*.app
*.deb
*.rpm
*.snap
*.bin
*.msm
*.msp
*.msu

# -------------------------------------------------------------------------
# 10. BACKEND SPECIFIC
# -------------------------------------------------------------------------
# Mock data files (JSON test fixtures — không phải source code)
backend/*.json
!backend/package.json
!backend/package-lock.json

# Docker
.docker/

# Prisma generated
src/generated/prisma/

# -------------------------------------------------------------------------
# 11. FRONTEND SPECIFIC
# -------------------------------------------------------------------------
*.local
.env.production
.env.staging

# Test files that shouldn't be in final repo
*.test.js
*.spec.js
*.stories.jsx

# -------------------------------------------------------------------------
# 12. MISCELLANEOUS
# -------------------------------------------------------------------------
*.tmp
*.swp
*.swo
*.bak
*.orig
*.old
*.backup
*.temp
*.cache
*.pid
*.seed
*.sgimgrc

# SSL certificates
*.crt
*.cert
*.p12
*.pfx

# Temporary files
tmp/
temp/
.tmp/
