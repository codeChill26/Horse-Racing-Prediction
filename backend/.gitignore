# =========================================================================
# BACKEND .gitignore — Node.js + Express + Prisma
# =========================================================================

# -------------------------------------------------------------------------
# 1. Dependencies
# -------------------------------------------------------------------------
node_modules/
.jspm_packages/
.npm/
.pnp
.pnp.js

# -------------------------------------------------------------------------
# 2. Environment & Secrets
# -------------------------------------------------------------------------
# CẢNH BÁO: Tuyệt đối không đẩy .env lên Git
# Nội dung .env có thể bao gồm:
#   - Database password / connection string
#   - JWT_SECRET
#   - Gmail API credentials
#   - Admin passwords
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
*.pem
*.key
credentials.json
secrets.json

# -------------------------------------------------------------------------
# 3. Build & Generated
# -------------------------------------------------------------------------
# Prisma generated client (nếu cấu hình custom output)
# /src/generated/prisma/

# Docker
.docker/

# -------------------------------------------------------------------------
# 4. Logs & Debug
# -------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Custom backend log files
be.log
be.err.log
*.log

# -------------------------------------------------------------------------
# 5. Editor & IDE
# -------------------------------------------------------------------------
# VS Code
.vscode/
!.vscode/extensions.json
!.vscode/launch.json

# JetBrains
.idea/
*.iml
*.ipr
*.iws

# Cursor workspace
.cursor/
.cursorrc

# OS
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# Temp
*.swp
*.swo
*.swn
*.tmp
*.bak
*.orig
*.old

# -------------------------------------------------------------------------
# 6. Test
# -------------------------------------------------------------------------
coverage/
.nyc_output/

# -------------------------------------------------------------------------
# 7. Python (nếu dùng)
# -------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# -------------------------------------------------------------------------
# 8. Cache
# -------------------------------------------------------------------------
.eslintcache
.parcel-cache/
.turbo/
.nuxt/
.next/

# -------------------------------------------------------------------------
# 9. Mock Data (JSON fixtures — chỉ dùng local dev)
# -------------------------------------------------------------------------
# Các file JSON mock data bên dưới nên được quản lý qua seed script
# thay vì commit lên git. Comment lại nếu cần giữ lại mẫu.
# *.json
