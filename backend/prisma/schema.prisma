// backend/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TournamentStatus {
  DRAFT
  OPEN
  ONGOING
  FINISHED
  CANCELLED
}

// 1. Thực thể Người dùng chính (Users)
model User {
  userId            Int               @id @default(autoincrement())
  email             String            @unique
  passwordHash      String
  fullName          String
  phoneNumber       String?
  avatarUrl         String?
  roleId            Int
  isActive          Boolean           @default(true)
  lockedUntil       DateTime?         // Thời gian tài khoản bị khóa tạm thời
  licenseNumber     String?           // Dành riêng cho nhóm Jockey
  weight            Decimal?          // Dành riêng cho nhóm Jockey
  bio               String?           // Dành riêng cho nhóm Jockey
  isProfileComplete Boolean           @default(false)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  refreshTokens     RefreshToken[]
  role              Role              @relation(fields: [roleId], references: [roleId])
  pointWallet       PointWallet?
  resetOtp          PasswordResetOtp?

  horses Horse[] @relation("HorseOwner")

  sentInvitations      JockeyInvitation[] @relation("SentInvitations")
  receivedInvitations  JockeyInvitation[] @relation("ReceivedInvitations")

  raceEntries RaceEntry[] @relation("JockeyRaceEntries")
}

// 2. Thực thể Vai trò hệ thống (Roles)
model Role {
  roleId    Int      @id @default(autoincrement())
  code      String   @unique // 'Admin', 'Referee', 'Horse Owner', 'Jockey', 'Spectator'
  name      String
  users     User[]
}

// 3. Ví điểm (PointWallets)
model PointWallet {
  walletId     Int                 @id @default(autoincrement())
  userId       Int                 @unique
  balance      Int                 @default(0)       // Số dư ví điểm
  isFrozen     Int                 @default(0)       // 0: Hoạt động, 1: Bị đóng băng
  rowVersion   Bytes               @default(dbgenerated("gen_random_bytes(8)")) // binary rowVersion chống Race Condition
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  user               User                @relation(fields: [userId], references: [userId])
  walletTransactions WalletTransaction[]
}

// 4. Lịch sử biến động số dư ví điểm (WalletTransactions)
model WalletTransaction {
  transactionId Int      @id @default(autoincrement())
  walletId      Int
  amount        Int      // Số điểm thay đổi (+/-)
  balanceAfter  Int      // Số dư ví điểm ngay sau giao dịch
  referenceType String?  // Loại tham chiếu ngoại bang (nvarchar)
  referenceId   BigInt?  // ID tham chiếu ngoại bang tương ứng (bigint)
  type          String   // Loại giao dịch: 'INITIAL_BONUS', 'DEPOSIT', 'BET_PLACED'
  description   String?  
  createdAt     DateTime @default(now())

  pointWallet   PointWallet @relation(fields: [walletId], references: [walletId])
}

// 5. Mã OTP phục vụ luồng Quên mật khẩu (PasswordResetOtps)
model PasswordResetOtp {
  otpId      Int      @id @default(autoincrement())
  userId     Int      @unique
  code       String
  expiryDate DateTime
  isUsed     Boolean  @default(false)
  createdAt  DateTime @default(now()) // Thời điểm sinh mã OTP vật lý

  user       User     @relation(fields: [userId], references: [userId])
}

model RefreshToken {
  tokenId    Int      @id @default(autoincrement())
  userId     Int
  token      String   @unique
  isRevoked  Boolean  @default(false)
  expiryDate DateTime
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [userId], onDelete: Cascade)
}

model Tournament {
  tournamentId Int             @id @default(autoincrement())
  name         String
  description  String?
  status       TournamentStatus @default(DRAFT)
  cancelReason String?
  startAt      DateTime?
  endAt        DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  races        Race[]
}

model Race {
  raceId       Int      @id @default(autoincrement())
  tournamentId Int
  name         String
  scheduledAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tournament   Tournament @relation(fields: [tournamentId], references: [tournamentId], onDelete: Restrict)

  @@index([tournamentId])

  invitations JockeyInvitation[]
  raceEntries RaceEntry[]
}

model Horse {
  horseId          Int       @id @default(autoincrement())
  ownerId          Int
  name             String
  breed            String?
  birthYear        Int?
  color            String?
  imageUrl         String?
  status HorseStatus @default(PENDING)
  rejectionReason  String?
  approvedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  owner User @relation( "HorseOwner", fields: [ownerId], references: [userId], onDelete: Cascade)

  invitations      JockeyInvitation[]
  raceEntries      RaceEntry[]

  @@index([ownerId])
  @@unique([ownerId, name])
}

model JockeyInvitation {
  invitationId Int              @id @default(autoincrement())
  raceId       Int
  horseId      Int
  ownerId      Int              
  jockeyId     Int              
  status       InvitationStatus @default(PENDING)
  declineReason String?         
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  // Quan hệ liên kết (Relationships)
  race         Race             @relation(fields: [raceId], references: [raceId], onDelete: Cascade)
  horse        Horse            @relation(fields: [horseId], references: [horseId], onDelete: Cascade)
  owner        User             @relation("SentInvitations", fields: [ownerId], references: [userId], onDelete: Cascade)
  jockey       User             @relation("ReceivedInvitations", fields: [jockeyId], references: [userId], onDelete: Cascade)

  @@unique([jockeyId, horseId, raceId]) 
  @@index([raceId])
  @@index([horseId])
  @@index([ownerId])
  @@index([jockeyId])
}

model RaceEntry {
  entryId   Int      @id @default(autoincrement())
  raceId    Int
  horseId   Int
  jockeyId  Int
  createdAt DateTime @default(now())

  race      Race     @relation(fields: [raceId], references: [raceId], onDelete: Cascade)
  horse     Horse    @relation(fields: [horseId], references: [horseId], onDelete: Cascade)
  jockey User @relation("JockeyRaceEntries", fields: [jockeyId], references: [userId], onDelete: Cascade)

  @@unique([raceId, horseId])  
  @@unique([raceId, jockeyId]) 
  @@index([raceId])
  @@index([horseId])
  @@index([jockeyId])
}

