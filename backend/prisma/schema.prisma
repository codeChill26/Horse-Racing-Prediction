// backend/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TournamentStatus {
  DRAFT
  OPEN
  ONGOING
  FINISHED
  CANCELLED
}

enum RaceEntryStatus {
  PENDING
  APPROVED
  REJECTED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELLED
  EXPIRED
}

enum HorseStatus {
  PENDING
  APPROVED
  REJECTED
  INACTIVE
}

enum RaceStatus {
  SCHEDULED
  IN_PROGRESS
  PENDING_RESULT
  PAUSED
  FINISHED
  CANCELLED
}

// Enum cho trạng thái đối chiếu kết quả của Trọng tài
enum SubmissionMatchStatus {
  PENDING // Đang chờ trọng tài còn lại nộp
  AUTO_MATCHED // Khớp 100%
  CONFLICTED // Lệch kết quả
  RESOLVED // Đã được Admin xử lý ghi đè
}

enum PredictionStatus {
  PENDING
  WON
  PARTIAL_WON
  LOST
  REFUNDED
}

enum BetType {
  WIN
  PLACE
  SHOW
  QUINELLA
  EXACTA
}

// 1. Thực thể Người dùng chính (Users)
model User {
  userId            Int       @id @default(autoincrement())
  email             String    @unique
  passwordHash      String
  fullName          String
  phoneNumber       String?
  avatarUrl         String?
  roleId            Int
  isActive          Boolean   @default(true)
  lockedUntil       DateTime? // Thời gian tài khoản bị khóa tạm thời
  licenseNumber     String? // Dành riêng cho nhóm Jockey
  weight            Decimal? // Dành riêng cho nhóm Jockey
  bio               String? // Dành riêng cho nhóm Jockey
  isProfileComplete Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  refreshTokens RefreshToken[]
  role          Role              @relation(fields: [roleId], references: [roleId])
  pointWallet   PointWallet?
  resetOtp      PasswordResetOtp?

  horsesOwned         Horse[]     @relation("HorseOwner")
  horsesReviewed      Horse[]     @relation("HorseReviewedBy")
  raceEntriesAsJockey RaceEntry[] @relation("RaceEntryJockey")
  raceEntriesReviewed RaceEntry[] @relation("RaceEntryReviewedBy")

  // Đã sửa lại tên nhãn quan hệ cho khớp với model JockeyInvitation bên dưới
  sentInvitations     JockeyInvitation[] @relation("InvitationOwner")
  receivedInvitations JockeyInvitation[] @relation("InvitationJockey")

  predictions Prediction[]

  // BỔ SUNG: Quan hệ phục vụ luồng phân công Trọng tài
  racesAsRefereeA    Race[]              @relation("RaceRefereeA")
  racesAsRefereeB    Race[]              @relation("RaceRefereeB")
  refereeSubmissions RefereeSubmission[]
}

// 2. Thực thể Vai trò hệ thống (Roles)
model Role {
  roleId Int    @id @default(autoincrement())
  code   String @unique // 'Admin', 'Referee', 'Horse Owner', 'Jockey', 'Spectator'
  name   String
  users  User[]
}

// 3. Ví điểm (PointWallets)
model PointWallet {
  walletId   Int      @id @default(autoincrement())
  userId     Int      @unique
  balance    Int      @default(0) // Số dư ví điểm
  isFrozen   Int      @default(0) // 0: Hoạt động, 1: Bị đóng băng
  rowVersion Bytes    @default(dbgenerated("gen_random_bytes(8)")) // binary rowVersion chống Race Condition
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user               User                @relation(fields: [userId], references: [userId])
  walletTransactions WalletTransaction[]
}

// 4. Lịch sử biến động số dư ví điểm (WalletTransactions)
model WalletTransaction {
  transactionId Int      @id @default(autoincrement())
  walletId      Int
  amount        Int // Số điểm thay đổi (+/-)
  balanceAfter  Int // Số dư ví điểm ngay sau giao dịch
  referenceType String? // Loại tham chiếu ngoại bang (nvarchar)
  referenceId   BigInt? // ID tham chiếu ngoại bang tương ứng (bigint)
  type          String // Loại giao dịch: 'INITIAL_BONUS', 'DEPOSIT', 'BET_PLACED', 'BET_REFUND', 'BET_WIN', 'BET_WIN_REVERSAL', 'WEEKLY_BONUS', 'ADMIN_ADJUSTMENT'
  description   String?
  createdAt     DateTime @default(now())

  pointWallet PointWallet @relation(fields: [walletId], references: [walletId])
}

// 5. Mã OTP phục vụ luồng Quên mật khẩu (PasswordResetOtps)
model PasswordResetOtp {
  otpId      Int      @id @default(autoincrement())
  userId     Int      @unique
  code       String
  expiryDate DateTime
  isUsed     Boolean  @default(false)
  createdAt  DateTime @default(now()) // Thời điểm sinh mã OTP vật lý

  user User @relation(fields: [userId], references: [userId])
}

model RefreshToken {
  tokenId    Int      @id @default(autoincrement())
  userId     Int
  token      String   @unique
  isRevoked  Boolean  @default(false)
  expiryDate DateTime
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)
}

model Tournament {
  tournamentId Int              @id @default(autoincrement())
  name         String
  description  String?
  status       TournamentStatus @default(DRAFT)
  cancelReason String?
  startAt      DateTime?
  endAt        DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  races Race[]
}

model Race {
  raceId               Int        @id @default(autoincrement())
  tournamentId         Int
  name                 String
  maxEntries           Int        @default(8)
  scheduledAt          DateTime?
  registrationDeadline DateTime?
  status               RaceStatus @default(SCHEDULED)
  publishedAt          DateTime?
  registrationOpen     Boolean    @default(false)
  registrationOpenedAt DateTime?
  registrationClosedAt DateTime?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  // BỔ SUNG: ID của 2 trọng tài được gán vào trận đấu này
  refereeAId Int?
  refereeBId Int?

  tournament  Tournament         @relation(fields: [tournamentId], references: [tournamentId], onDelete: Restrict)
  entries     RaceEntry[]
  results     RaceResult[]
  invitations JockeyInvitation[]
  predictions Prediction[]
  odds        Odds[]

  // BỔ SUNG: Quan hệ tới luồng nộp điểm Blind Entry
  refereeA           User?               @relation("RaceRefereeA", fields: [refereeAId], references: [userId], onDelete: SetNull)
  refereeB           User?               @relation("RaceRefereeB", fields: [refereeBId], references: [userId], onDelete: SetNull)
  refereeSubmissions RefereeSubmission[]
  officialRaceResult OfficialRaceResult?

  @@index([tournamentId])
}

model Horse {
  horseId         Int         @id @default(autoincrement())
  ownerId         Int
  name            String
  breed           String?
  dateOfBirth     DateTime?
  birthYear       Int?
  imageUrl        String?
  sex             String?
  color           String?
  status          HorseStatus @default(PENDING)
  rejectionReason String?
  approvedAt      DateTime?
  rejectedAt      DateTime?
  reviewedById    Int?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // Rating phong độ cho AI Prediction Engine (Agent 1). Admin cập nhật thủ công,
  // nullable vì ngựa mới chưa có rating -> model tự impute median khi thiếu.
  officialRating   Int? // OR - Official Rating
  racingPostRating Int? // RPR - Racing Post Rating

  owner      User  @relation("HorseOwner", fields: [ownerId], references: [userId], onDelete: Restrict)
  reviewedBy User? @relation("HorseReviewedBy", fields: [reviewedById], references: [userId], onDelete: SetNull)

  entries     RaceEntry[]
  results     RaceResult[]
  invitations JockeyInvitation[]

  @@unique([ownerId, name])
  @@index([ownerId])
  @@index([status])
}

model RaceEntry {
  entryId         Int             @id @default(autoincrement())
  raceId          Int
  horseId         Int
  jockeyId        Int?
  status          RaceEntryStatus @default(PENDING)
  rejectionReason String?
  reviewedById    Int?
  reviewedAt      DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  // Thông tin riêng cho lượt đua này (không phải thuộc tính cố định của ngựa),
  // dùng làm feature cho AI Prediction Engine. Admin/Referee nhập lúc duyệt entry.
  weightLb     Int? // Cân nặng ngựa mang khi vào đua
  saddleNumber Int? // Số ô xuất phát (draw)

  // Snapshot rating của ngựa TẠI thời điểm vào đua (chốt lúc duyệt entry). Horse.OR/RPR
  // là giá trị hiện tại và sẽ bị cập nhật sau mỗi đua; snapshot giữ lại rating cũ để
  // không làm sai lệch dữ liệu lịch sử của các lượt đua đã qua.
  officialRatingSnapshot   Int? // OR tại lúc vào đua
  racingPostRatingSnapshot Int? // RPR tại lúc vào đua

  race       Race  @relation(fields: [raceId], references: [raceId], onDelete: Restrict)
  horse      Horse @relation(fields: [horseId], references: [horseId], onDelete: Restrict)
  jockey     User? @relation("RaceEntryJockey", fields: [jockeyId], references: [userId], onDelete: SetNull)
  reviewedBy User? @relation("RaceEntryReviewedBy", fields: [reviewedById], references: [userId], onDelete: SetNull)

  pickedAs1    Prediction[] @relation("Pick1")
  pickedAs2    Prediction[] @relation("Pick2")
  odds         Odds[]

  @@unique([raceId, horseId])
  @@unique([raceId, jockeyId])
  @@index([horseId])
  @@index([jockeyId])
  @@index([status])
}

model JockeyInvitation {
  invitationId  Int              @id @default(autoincrement())
  ownerId       Int
  jockeyId      Int
  horseId       Int
  raceId        Int
  status        InvitationStatus @default(PENDING)
  declineReason String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  // Đã đồng bộ tên quan hệ trùng khớp hoàn toàn với model User
  owner  User  @relation("InvitationOwner", fields: [ownerId], references: [userId], onDelete: Restrict)
  jockey User  @relation("InvitationJockey", fields: [jockeyId], references: [userId], onDelete: Restrict)
  horse  Horse @relation(fields: [horseId], references: [horseId], onDelete: Restrict)
  race   Race  @relation(fields: [raceId], references: [raceId], onDelete: Restrict)

  @@unique([jockeyId, horseId, raceId])
  @@index([ownerId])
  @@index([jockeyId])
}

model RaceResult {
  resultId       Int      @id @default(autoincrement())
  raceId         Int
  horseId        Int
  finishPosition Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  race  Race  @relation(fields: [raceId], references: [raceId], onDelete: Restrict)
  horse Horse @relation(fields: [horseId], references: [horseId], onDelete: Restrict)

  @@unique([raceId, horseId])
  @@index([horseId])
}

model Odds {
  oddsId         Int      @id @default(autoincrement())
  raceId         Int
  entryId        Int      @unique
  horseStrength  Decimal  @default(0)
  jockeyStrength Decimal?
  totalStrength  Decimal  @default(0)
  oddsRaw        Decimal  @default(1.0)
  oddsFinal      Decimal  @default(1.0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  race  Race      @relation(fields: [raceId], references: [raceId], onDelete: Restrict)
  entry RaceEntry @relation(fields: [entryId], references: [entryId], onDelete: Restrict)

  @@index([raceId])
}

model Prediction {
  predictionId Int              @id @default(autoincrement())
  spectatorId  Int
  raceId       Int
  betType      BetType
  entryId1     Int
  entryId2     Int?
  betAmount    Int
  lockedOdds   Decimal          @default(1.0)
  status       PredictionStatus @default(PENDING)
  payout       Int?
  settledAt    DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  spectator User      @relation(fields: [spectatorId], references: [userId])
  race      Race      @relation(fields: [raceId], references: [raceId], onDelete: Restrict)
  pick1     RaceEntry @relation("Pick1", fields: [entryId1], references: [entryId])
  pick2     RaceEntry? @relation("Pick2", fields: [entryId2], references: [entryId])

  @@index([spectatorId])
  @@index([raceId])
  @@index([status])
}

// =========================================================================
// BỔ SUNG CÁC MODEL PHỤC VỤ CHO FLOW 4: BLIND DOUBLE ENTRY
// =========================================================================

// Model lưu kết quả nộp độc lập của từng trọng tài (Append-Only)
model RefereeSubmission {
  submissionId Int      @id @default(autoincrement())
  raceId       Int
  refereeId    Int
  submittedAt  DateTime @default(now())

  // Dữ liệu JSON lưu chi tiết thứ hạng (Ví dụ: [{"entryId": 12, "rank": 1, "isDnf": false, "isDq": false}])
  rawResults Json

  race    Race @relation(fields: [raceId], references: [raceId], onDelete: Restrict)
  referee User @relation(fields: [refereeId], references: [userId], onDelete: Restrict)

  @@unique([raceId, refereeId]) // Khóa ràng buộc: Mỗi trọng tài chỉ nộp 1 lần cho 1 trận đấu
  @@index([raceId])
}

// Model lưu trạng thái so sánh kết quả và là nơi để Admin xử lý ghi đè
model OfficialRaceResult {
  officialResultId Int                   @id @default(autoincrement())
  raceId           Int                   @unique // 1 trận đấu chỉ có duy nhất 1 bảng trạng thái kết quả chính thức
  matchStatus      SubmissionMatchStatus @default(PENDING)

  // Kết quả cuối cùng chốt hạ sau khi so sánh hoặc sau khi Admin chỉnh sửa thủ công
  finalResults Json

  resolvedById  Int? // ID Admin xử lý nếu trạng thái bị CONFLICTED
  resolveReason String? // Lý do bắt buộc khi Admin can thiệp ghi đè kết quả
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  race Race @relation(fields: [raceId], references: [raceId], onDelete: Restrict)
}
