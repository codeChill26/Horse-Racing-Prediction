# =========================================================================
# FRONTEND .gitignore — Vite + React
# =========================================================================

# -------------------------------------------------------------------------
# 1. Dependencies
# -------------------------------------------------------------------------
node_modules/
.pnp
.pnp.js

# -------------------------------------------------------------------------
# 2. Build Output
# -------------------------------------------------------------------------
dist/
dist-ssr/
*.local

# -------------------------------------------------------------------------
# 3. Environment & Secrets
# -------------------------------------------------------------------------
.env
.env.local
.env.*.local
.env.production
.env.staging

# -------------------------------------------------------------------------
# 4. Logs
# -------------------------------------------------------------------------
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.log

# -------------------------------------------------------------------------
# 5. Editor & IDE
# -------------------------------------------------------------------------
# VS Code
.vscode/
!.vscode/extensions.json
!.vscode/settings.json

# JetBrains / WebStorm
.idea/
*.iml
*.ipr
*.iws

# Cursor workspace (bộ nhớ ngữ cảnh AI)
.cursor/
.cursorrc

# OS
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# Temp files
*.swp
*.swo
*.swn
*.tmp
*.bak
*.orig

# -------------------------------------------------------------------------
# 6. Test & Coverage
# -------------------------------------------------------------------------
coverage/
.nyc_output/

# -------------------------------------------------------------------------
# 7. Cursor & Agent artifacts (bộ nhớ ngữ cảnh)
# -------------------------------------------------------------------------
/cursor.md
**/cursor.md
